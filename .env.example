# ─────────────────────────────────────────────────────────────
#  J1.Notes — Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── Security (REQUIRED — change before exposing to internet) ─
JWT_SECRET=change-me-to-a-long-random-secret

# ── Database ─────────────────────────────────────────────────
# "sqlite" (default) or "postgresql"
DATABASE_PROVIDER=sqlite

# SQLite (default):
DATABASE_URL=file:/data/j1notes.db

# PostgreSQL (use with docker-compose.postgres.yml):
# DATABASE_URL=postgresql://j1notes:secret@db:5432/j1notes

# ── Email / Password Reset (optional) ────────────────────────
# Leave empty to disable the "Forgot password" feature.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=J1.Notes <no-reply@j1notes.local>

# ── UI (optional) ────────────────────────────────────────────
# Override the GitHub link shown in the footer.
# Baked in at build time (Next.js NEXT_PUBLIC_ variable).
# NEXT_PUBLIC_GITHUB_URL=https://github.com/x3kim/J1.Notes
